# ignore everything by default
*

# keep this file tracked
!.gitignore

# managed directories
!superarch/
!superarch/**

!alacritty/
!alacritty/**

!niri/
!niri/**

!tmux/
!tmux/**

!nvim/
!nvim/**

# managed systemd user units
# ignore all systemd state by default
systemd/**

# allow the directories
!systemd/
!systemd/user/

# ignore everything under user (including wants/)
systemd/user/**

# track only the two unit symlinks at top-level
!systemd/user/theme.service
!systemd/user/theme.path

# never track enablement state
systemd/user/*wants/
systemd/user/*wants/**

# -------------------------
# generated files (do not track)
# -------------------------
superarch/current/
superarch/current/**
