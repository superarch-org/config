#!/bin/bash
set -euo pipefail

lang_id="$1"

if [ -z "$lang_id" ]; then
  echo "Usage: nvim-add-language <language>"
  echo ""
  echo "Available languages:"
echo "  bash, c, go, html, javascript, json, lua, markdown, python, rust, svelte, yaml"
  exit 1
fi

# Map language to Mason packages (LSP + formatters)
case "$lang_id" in
  bash)
    lsp="bash-language-server"
    formatters="shfmt"
    ;;
  c)
    lsp="clangd"
    formatters="clang-format"
    ;;
  go)
    lsp="gopls"
    formatters="gofmt goimports"
    ;;
  html)
    lsp="html-lsp"
    formatters="prettier"
    ;;
  javascript)
    lsp="typescript-language-server"
    formatters="eslint-lsp"
    ;;
  svelte)
    lsp="svelte-language-server"
    formatters=""
    ;;
  json)
    lsp="json-lsp"
    formatters="prettier"
    ;;
  lua)
    lsp="lua-language-server"
    formatters="stylua"
    ;;
  markdown)
    lsp="marksman"
    formatters="prettier"
    ;;
  python)
    lsp="pyright"
    formatters="ruff"
    ;;
  rust)
    lsp="rust-analyzer"
    formatters="rustfmt"
    ;;
  yaml)
    lsp="yaml-language-server"
    formatters="prettier"
    ;;
  zig)
    lsp="zls"
    formatters=""
    ;;
  *)
    echo "Unknown language: $lang_id"
    exit 1
    ;;
esac

echo "Installing LSP: $lsp"
nvim --headless -c "MasonInstall $lsp" -c "sleep 3" -c qa

echo "Installing formatters: $formatters"
if [ -n "$formatters" ]; then
  for formatter in $formatters; do
    nvim --headless -c "MasonInstall $formatter" -c "sleep 2" -c qa
  done
fi

# Enable in config
config_dir="$HOME/.config/current"
config_file="$config_dir/nvim-languages.json"

mkdir -p "$config_dir"

if [ -f "$config_file" ]; then
  existing=$(cat "$config_file")
else
  existing="{}"
fi

echo "$existing" | jq --arg lang "$lang_id" '.[$lang] = true' > "$config_file"

echo "✓ Installed and enabled $lang_id"
echo "Restart nvim to activate!"
