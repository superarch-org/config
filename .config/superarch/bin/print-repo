#!/usr/bin/env node
import { promises as fs } from "fs";
import path from "path";

const args = process.argv.slice(2);

// --- parse CLI ---
function parseArg(name, fallback = null) {
  const prefix = `--${name}=`;
  const item = args.find(a => a.startsWith(prefix));
  return item ? item.slice(prefix.length) : fallback;
}

const rootDir = parseArg("dir", process.cwd());
const extArg = parseArg("extensions", null); // null => use all files

const exts =
  extArg && typeof extArg === "string"
    ? new Set(
      extArg
        .split(",")
        .map(s => s.trim().toLowerCase())
        .filter(Boolean)
    )
    : null;

// 🔧 default ignores for monorepos etc.
const DEFAULT_IGNORE_PATTERNS = [
  ".git",
  ".gitignore",
  "node_modules",
  "lib",
  "dist",
  "build",
  "coverage",
  ".turbo",
  ".next",
];

// Parse .gitignore patterns
async function parseGitignore(rootPath) {
  const gitignorePath = path.join(rootPath, ".gitignore");

  // start with defaults
  const patterns = [...DEFAULT_IGNORE_PATTERNS];

  try {
    const content = await fs.readFile(gitignorePath, "utf8");
    const lines = content.split("\n");

    for (let line of lines) {
      line = line.trim();
      if (!line || line.startsWith("#")) continue;
      patterns.push(line);
    }
  } catch {
    // no .gitignore or unreadable, just use defaults
  }

  return patterns;
}

// Check if a path matches any gitignore pattern
function shouldIgnore(relativePath, patterns) {
  const normalized = relativePath.replace(/\\/g, "/");

  for (const pattern of patterns) {
    if (pattern.startsWith("!")) continue; // ignoring negation for now

    // Exact directory or file match
    if (pattern === normalized) return true;

    // Directory pattern ending with /
    if (pattern.endsWith("/")) {
      const dirPattern = pattern.slice(0, -1);
      if (normalized === dirPattern || normalized.startsWith(dirPattern + "/")) {
        return true;
      }
    }

    // Root-only pattern
    if (pattern.startsWith("/")) {
      const rootPattern = pattern.slice(1);
      if (normalized === rootPattern || normalized.startsWith(rootPattern + "/")) {
        return true;
      }
      continue;
    }

    // Match any segment in the path
    const parts = normalized.split("/");
    for (let i = 0; i < parts.length; i++) {
      const segment = parts.slice(i).join("/");

      if (pattern.includes("*")) {
        const regex = new RegExp("^" + pattern.replace(/\*/g, ".*") + "$");
        if (regex.test(segment) || regex.test(parts[i])) return true;
      } else {
        if (segment === pattern || parts[i] === pattern) return true;
      }
    }
  }

  return false;
}

async function walk(dir, rootPath, ignorePatterns) {
  let entries;
  try {
    entries = await fs.readdir(dir, { withFileTypes: true });
  } catch {
    return;
  }

  for (const ent of entries) {
    const full = path.join(dir, ent.name);
    const rel = path.relative(rootPath, full);

    if (shouldIgnore(rel, ignorePatterns)) {
      continue;
    }

    if (ent.isDirectory()) {
      await walk(full, rootPath, ignorePatterns);
      continue;
    }

    if (!ent.isFile()) continue;

    const ext = path.extname(ent.name).toLowerCase();
    if (exts && !exts.has(ext)) continue;

    try {
      const buf = await fs.readFile(full, "utf8");
      process.stdout.write(`// begin of ${rel}\n`);
      process.stdout.write(buf.endsWith("\n") ? buf : buf + "\n");
      process.stdout.write(`// end of ${rel}\n\n`);
    } catch {
      // skip unreadable / binary-ish files
    }
  }
}

(async () => {
  const start = path.resolve(rootDir);
  const ignorePatterns = await parseGitignore(start);
  await walk(start, start, ignorePatterns);
})();
